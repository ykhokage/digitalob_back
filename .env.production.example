NODE_ENV=production
PORT=4000
FRONTEND_URL=https://your-vercel-app.vercel.app

DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

JWT_ACCESS_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_long_random_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

RESEND_API_KEY=
RESEND_FROM=Цифровой Наблюдатель <noreply@example.com>

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
MAX_BOT_TOKEN=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@incidents64.fun

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
NOTIFICATIONS_REQUIRE_REDIS=true
RUN_WORKER_IN_API=false
DASHBOARD_CACHE_TTL_SEC=20

S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
STORAGE_REQUIRE_S3=true
